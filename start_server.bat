@echo off
chcp 65001 > nul
setlocal EnableDelayedExpansion

:: ════════════════════════════════════════════════════════════════════════
::  БАЗА v2 — Автозапуск сервера
::  Сохраните файл в корневую папку проекта рядом с server.js
:: ════════════════════════════════════════════════════════════════════════

title БАЗА v2 — Сервер

:: Цвета: фон чёрный, текст ярко-зелёный
color 0A

cls
echo.
echo   ██████╗  █████╗ ███████╗ █████╗
echo   ██╔══██╗██╔══██╗╚════██║██╔══██╗
echo   ██████╔╝███████║    ██╔╝███████║
echo   ██╔══██╗██╔══██║   ██╔╝ ██╔══██║
echo   ██████╔╝██║  ██║   ██║  ██║  ██║
echo   ╚═════╝ ╚═╝  ╚═╝   ╚═╝  ╚═╝  ╚═╝
echo.
echo   ──────────────────────────────────────────────────────
echo    Super App  ^|  Защищённая коммуникация  ^|  v2.0
echo   ──────────────────────────────────────────────────────
echo.

:: Переходим в папку, где лежит .bat
cd /d "%~dp0"

:: ────────────────────────────────────────────────────────────────────────
:: ШАГ 1 — Node.js
:: ────────────────────────────────────────────────────────────────────────
call :step "1/6" "Проверка Node.js"
where node >nul 2>&1
if errorlevel 1 (
    call :fail "Node.js не установлен"
    echo.
    echo   Скачайте с: https://nodejs.org/
    echo.
    pause & exit /b 1
)
for /f "tokens=*" %%v in ('node --version 2^>nul') do set NODE_VER=%%v
call :ok "Node.js %NODE_VER%"

:: ────────────────────────────────────────────────────────────────────────
:: ШАГ 2 — npm
:: ────────────────────────────────────────────────────────────────────────
call :step "2/6" "Проверка npm"
where npm >nul 2>&1
if errorlevel 1 (
    call :fail "npm не найден"
    pause & exit /b 1
)
for /f "tokens=*" %%v in ('npm --version 2^>nul') do set NPM_VER=%%v
call :ok "npm v%NPM_VER%"

:: ────────────────────────────────────────────────────────────────────────
:: ШАГ 3 — Зависимости
:: ────────────────────────────────────────────────────────────────────────
call :step "3/6" "Проверка зависимостей"
if not exist "package.json" (
    call :fail "package.json не найден. Запустите из папки проекта!"
    pause & exit /b 1
)
if not exist "node_modules" (
    echo.
    echo   [!] node_modules не найден — запускаю npm install...
    echo.
    call npm install
    if errorlevel 1 (
        call :fail "npm install завершился с ошибкой"
        pause & exit /b 1
    )
    call :ok "Зависимости установлены"
) else (
    call :ok "node_modules уже существует"
)

:: ────────────────────────────────────────────────────────────────────────
:: ШАГ 4 — Папки для медиа-файлов
:: ────────────────────────────────────────────────────────────────────────
call :step "4/6" "Создание папок"
for %%D in (uploads voice videos stickerpack) do (
    if not exist "%%D" (
        mkdir "%%D" >nul 2>&1
        echo   [+] Создана папка: %%D
    )
)
call :ok "Папки готовы"

:: ────────────────────────────────────────────────────────────────────────
:: ШАГ 5 — .env файл
:: ────────────────────────────────────────────────────────────────────────
call :step "5/6" "Файл окружения .env"
if not exist ".env" (
    echo.
    echo   [!] .env не найден — создаю...
    if exist ".env.example" (
        copy ".env.example" ".env" >nul
        echo   [+] Скопирован из .env.example
    ) else (
        (
            echo PORT=3000
            echo BAZA_ADMIN_KEY=adminmmnnoomm12
            echo MISTRAL_API_KEY=
            echo GROQ_API_KEY=
            echo SMTP_USER=
            echo SMTP_PASS=
            echo DATABASE_URL=
        ) > .env
        echo   [+] Создан .env по умолчанию
    )
    echo.
    echo   ╔════════════════════════════════════════════╗
    echo   ║  Откройте .env и заполните API-ключи:     ║
    echo   ║  MISTRAL_API_KEY  — для AI функций        ║
    echo   ║  SMTP_USER/PASS   — для email верификации ║
    echo   ╚════════════════════════════════════════════╝
    echo.
    echo   Нажмите любую клавишу для продолжения...
    pause >nul
)
call :ok ".env готов"

:: ────────────────────────────────────────────────────────────────────────
:: ШАГ 6 — ComfyUI (опционально)
:: ────────────────────────────────────────────────────────────────────────
call :step "6/6" "ComfyUI (опционально)"
set "COMFY=%~dp0ComfyUI_windows_portable"
if exist "%COMFY%\run_nvidia_gpu.bat" (
    echo   [~] Запускаю ComfyUI в фоне...
    start "ComfyUI" cmd /k "cd /d %COMFY% && run_nvidia_gpu.bat --listen 0.0.0.0"
    timeout /t 8 /nobreak >nul
    call :ok "ComfyUI запущен (порт 8188)"
) else (
    echo   [-] ComfyUI не найден — используется Pollinations API
)

:: ────────────────────────────────────────────────────────────────────────
:: ШАГ 7 — Туннелирование (Serveo)
:: ────────────────────────────────────────────────────────────────────────
call :step "7/7" "Туннелирование через Serveo"
echo.
echo   [~] Попытка проброса порта 3000 в сеть...
echo   [!] ВНИМАНИЕ: Ссылка вида 'https://xxxx.serveo.net' появится ниже.
echo.

:: Запускаем SSH-туннель в отдельном окне
start "BAZA_SERVEO" cmd /k "ssh -R 80:localhost:3000 serveo.net"

:: Даем время на установку соединения
timeout /t 5 /nobreak >nul
call :ok "Запрос на туннель отправлен"

:: ────────────────────────────────────────────────────────────────────────
:: ЗАПУСК
:: ────────────────────────────────────────────────────────────────────────
echo.
echo   ════════════════════════════════════════════════════════
echo.
echo   Запуск БАЗА сервера...
echo.
echo   ┌─────────────────────────────────────────────────────┐
echo   │  Локально:    http://localhost:3000                 │
echo   │  Админ:       http://localhost:3000/admin           │
echo   │  Premium:     http://localhost:3000/premium         │
echo   │  Кошелёк:     http://localhost:3000/wallet.html     │
echo   └─────────────────────────────────────────────────────┘
echo.
echo   Для остановки нажмите  Ctrl+C
echo   Авто-перезапуск при краше (до 5 раз)
echo.
echo   ════════════════════════════════════════════════════════
echo.

:: ────────────────────────────────────────────────────────────────────────
:: ЦИКЛ ПЕРЕЗАПУСКА
:: ────────────────────────────────────────────────────────────────────────
set RESTARTS=0

:run_server
node server.js
set /a EXIT=%ERRORLEVEL%

:: Корректная остановка (код 0) — выходим
if %EXIT% EQU 0 goto :stopped

set /a RESTARTS+=1
echo.
echo   ─────────────────────────────────────────────────────
echo   [!] Сервер упал с кодом %EXIT%  ^(попытка %RESTARTS%/5^)
echo   ─────────────────────────────────────────────────────

if %RESTARTS% GEQ 5 (
    echo.
    echo   ╔════════════════════════════════════════════╗
    echo   ║  Превышен лимит перезапусков!              ║
    echo   ║  Проверьте server.js на ошибки.            ║
    echo   ╚════════════════════════════════════════════╝
    echo.
    pause & exit /b %EXIT%
)

echo   Перезапуск через 5 секунд...  Ctrl+C для выхода
timeout /t 5 /nobreak >nul
echo.
goto :run_server

:stopped
echo.
echo   Сервер остановлен.
echo.
pause
exit /b 0

:: ════════════════════════════════════════════════════════════════════════
:: ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ
:: ════════════════════════════════════════════════════════════════════════

:step
echo.
echo   ┌─ Шаг %~1 ──────────────────────────────────────────┐
echo   │  %~2
echo   └───────────────────────────────────────────────────┘
exit /b 0

:ok
echo   [OK] %~1
exit /b 0

:fail
echo.
echo   [ОШИБКА] %~1
echo.
exit /b 0