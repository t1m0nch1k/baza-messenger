# ════════════════════════════════════════════════════════════════════════
#  БАЗА v2 — .gitignore
# ════════════════════════════════════════════════════════════════════════

# ── Node.js ─────────────────────────────────────────────────────────────
node_modules/
package-lock.json
npm-debug.log*

# ── База данных (SQLite) ────────────────────────────────────────────────
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# ── Переменные окружения ────────────────────────────────────────────────
.env
.env.local
.env.production
*.env

# ── Загруженные файлы (медиа, голосовые, видео) ─────────────────────────
uploads/
voice/
videos/
stickerpack/
!uploads/.gitkeep
!voice/.gitkeep
!videos/.gitkeep
!stickerpack/.gitkeep

# ── Логи ────────────────────────────────────────────────────────────────
*.log
logs/
error.log

# ── Временные файлы и ОС ────────────────────────────────────────────────
tmp/
temp/
Thumbs.db
.DS_Store
*.tmp

# ── Бинарники и инструменты ─────────────────────────────────────────────
cloudflared.exe
ngrok.exe
*.exe

# ── IDE и редакторы ────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Сборка (если будет) ─────────────────────────────────────────────────
dist/
build/