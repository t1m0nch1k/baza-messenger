# PostgreSQL подключение
DATABASE_URL=postgres://postgres:postgres@localhost:5432/baza

# Или отдельные переменные (если DATABASE_URL не указан)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=baza
DB_USER=postgres
DB_PASSWORD=postgres

# Порт сервера
PORT=3000

# JWT секрет
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Настройки для nodemailer (опционально)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# AI ключи (опционально)
GROQ_API_KEY=
MISTRAL_API_KEY=
